#!/bin/sh
#
# pre-commit hook: block commits that introduce RUSSIAN text.
#
# English and Ukrainian are allowed; only Russian is rejected. Because the two
# languages share most of the Cyrillic block, we cannot ban all Cyrillic.
# Instead we look for signals that are specific to Russian and absent from the
# Ukrainian alphabet:
#   1. the letters 褗 褘 褝 褢 (Ukrainian uses ' / 褨 / 械 / 褦 instead), and
#   2. a curated list of common Russian words that are not valid Ukrainian.
# Ukrainian-only letters (褨 褩 褦 覒) and Ukrainian words never trigger the hook.
#
# Only staged content is scanned (never the working tree or dependencies),
# and binary files plus common vendored/lock paths are skipped.

# Russian detector, applied to a stream on stdin. Prints matching lines as
# "<line-number>: <line-content>". `-CSD` decodes stdin as UTF-8 and `-Mutf8`
# decodes this script's own Cyrillic literals, so both sides are compared as
# Unicode code points rather than raw bytes.
scan() {
	perl -CSD -Mutf8 -ne '
		# 1. Letters that exist in Russian but not in the Ukrainian alphabet.
		if (/[褗褘褝褢歇蝎协衼]/) { print "    line $.: $_"; next }
		# 2. Characteristic Russian words, matched as whole Cyrillic tokens
		#    (case-insensitive). Each is chosen so it is NOT a valid Ukrainian
		#    word, and the lookarounds keep Ukrainian words that merely contain
		#    these letters from matching.
		if (/(?<!\p{Cyrillic})(?:褝褌芯|褝褌芯褌|褝褌邪|褝褌懈|褔褌芯|褔褌芯斜褘|锌芯褌芯屑褍|锌芯褔械屑褍|械褋谢懈|懈谢懈|薪械褌|泻邪泻|泻邪泻芯泄|泻芯谐写邪|褋械泄褔邪褋|芯褔械薪褜|褋锌邪褋懈斜芯|锌芯卸邪谢褍泄褋褌邪|锌褉懈胁械褌|蟹写褉邪胁褋褌胁褍泄褌械|褏芯褉芯褕芯|锌谢芯褏芯|泻芯褌芯褉褘泄|泻芯褌芯褉褘械|泻芯褌芯褉褘褏|胁褉械屑褟|锌芯谢褜蟹芯胁邪褌械谢褜|薪邪褋褌褉芯泄泻懈|褍写邪谢懈褌褜|褋芯褏褉邪薪懈褌褜|写芯斜邪胁懈褌褜|懈蟹屑械薪懈褌褜|芯褕懈斜泻邪|褌芯谢褜泻芯|械褖褢|械褖械|胁褋械谐写邪|薪褍卸薪芯|蟹写械褋褜|褋械谐芯写薪褟|褉褍褋褋泻懈泄|褉褍褋褋泻芯屑|褉褍褋褋泻芯谐芯)(?!\p{Cyrillic})/i) {
			print "    line $.: $_";
		}
	'
}

found=0

# Read staged file paths one per line. `IFS=` and `read -r` keep spaces in
# paths intact. --diff-filter=ACM: only Added, Copied, Modified (skip
# deletions). Newlines inside file names are not supported (extremely rare).
while IFS= read -r file; do
	[ -n "$file" ] || continue
	# Skip dependency, virtualenv and lock files; the Ukrainian localisation
	# files (legitimately full of Cyrillic); and this hook itself (it must
	# contain Russian sample words/letters in order to detect them).
	case "$file" in
	node_modules/* | */node_modules/*) continue ;;
	.venv/* | */.venv/*) continue ;;
	*.lock | *-lock.json | *-lock.yaml | *-lock.yml) continue ;;
	package-lock.json | */package-lock.json) continue ;;
	src/i18n/uk.ts | */i18n/uk.ts | i18n/uk.ts) continue ;;
	.githooks/pre-commit | */.githooks/pre-commit) continue ;;
	esac

	# Skip binary files. `git diff --cached --numstat` prints "-" for the
	# added/removed line counts of a binary blob.
	numstat=$(git diff --cached --numstat -- "$file")
	case "$numstat" in
	"-"*) continue ;;
	esac

	# Scan the exact staged blob (":$file" is the staged version).
	matches=$(git show ":$file" 2>/dev/null | scan)
	if [ -n "$matches" ]; then
		if [ "$found" -eq 0 ]; then
			echo "Commit blocked: Russian text found in staged files." >&2
			echo "English and Ukrainian are allowed; Russian is not." >&2
			echo >&2
		fi
		found=1
		echo "  $file" >&2
		echo "$matches" >&2
	fi
done <<EOF
$(git diff --cached --name-only --diff-filter=ACM)
EOF

if [ "$found" -ne 0 ]; then
	echo >&2
	echo "Remove the Russian text and commit again." >&2
	exit 1
fi

exit 0
